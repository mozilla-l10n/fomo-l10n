#: foundation_cms/templates/patterns/blocks/themes/default/fragments/donor_help_contact_us_form/formassembly_body.html:106
msgid "JPG, PNG and BMP files only"
msgstr "Fichiers JPG, PNG et BMP UNIQUEMENT"

